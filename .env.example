# Telegram bot alerts (required for notifications)
# Create a bot via @BotFather on Telegram, then message your bot once and
# visit https://api.telegram.org/bot<TOKEN>/getUpdates to find your chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Adzuna (https://developer.adzuna.com/) - free tier, 250 calls/day
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Jooble (https://jooble.org/api/about) - free API key
JOOBLE_API_KEY=

# Gmail API (for parsing LinkedIn job-alert emails)
# See README "LinkedIn via Gmail" section for how to obtain these.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# Path to the SQLite database file (defaults to ./storage/jobs.db)
DB_PATH=
